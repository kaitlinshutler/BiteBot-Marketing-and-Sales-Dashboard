# Google Cloud Service Account Credentials
# Get these from your Google Cloud Console service account
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Google Spreadsheet ID (from the URL of your spreadsheet)
# e.g., https://docs.google.com/spreadsheets/d/THIS_IS_THE_ID/edit
GOOGLE_SPREADSHEET_ID=your-spreadsheet-id-here

# Cache duration in seconds (default 30)
CACHE_DURATION_SECONDS=30
